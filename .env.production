# vite build (npm run build) 일 때 자동 적용 — 배포용
# Phase 2(ALB) 생성 후 실제 주소로 교체할 것. 아래는 자리표시자.
#   - HTTPS(ACM/도메인) 적용 시: https://api.example.com / https://ai.example.com
#   - 도메인 없이 ALB DNS로 테스트 시: http://<alb-dns>  (backend/ai 경로 분리에 따라 조정)
VITE_API_BASE=https://CHANGE_ME_BACKEND_ORIGIN
VITE_AI_BASE=https://CHANGE_ME_AI_ORIGIN
